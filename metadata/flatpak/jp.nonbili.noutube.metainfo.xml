<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>jp.nonbili.noutube</id>

  <name>NouTube</name>
  <summary>YouTube and YouTube Music in a single app</summary>

  <developer id="jp.nonbili">
    <name>Nonbili Inc.</name>
  </developer>

  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>

  <branding>
    <color type="primary" scheme_preference="light">#99c1f1</color>
    <color type="primary" scheme_preference="dark">#a599a5</color>
  </branding>

  <description>
    <ul>
      <li>Manage video/music library without login</li>
      <li>Manage watch history without login</li>
      <li>No ads</li>
      <li>Download video</li>
      <li>Hide shorts</li>
      <li>Sponsor block</li>
    </ul>
  </description>

  <keywords>
    <keyword>youtube</keyword>
    <keyword>youtube-music</keyword>
    <keyword>yt</keyword>
    <keyword>yt-music</keyword>
    <keyword>yt-dlp</keyword>
  </keywords>

  <launchable type="desktop-id">jp.nonbili.noutube.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nonbili/NouTube-Desktop/942f89c4def0dabaa89fa0e08cbe3942bcb76926/metadata/screenshots/1.png</image>
      <caption>YouTube Music</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nonbili/NouTube-Desktop/942f89c4def0dabaa89fa0e08cbe3942bcb76926/metadata/screenshots/2.png</image>
      <caption>YouTube</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nonbili/NouTube-Desktop/942f89c4def0dabaa89fa0e08cbe3942bcb76926/metadata/screenshots/3.png</image>
      <caption>YouTube Channel Feeds</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/nonbili/NouTube-Desktop</url>
  <url type="vcs-browser">https://github.com/nonbili/NouTube</url>
  <url type="bugtracker">https://github.com/nonbili/NouTube/issues</url>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.2.11" date="2026-06-05">
      <description>
        <ul>
          <li>Sync settings and user styles/scripts</li>
          <li>Support pinning user scripts to toolbar</li>
          <li>Do not restore tabs on startup when restoreOnStart is disabled</li>
          <li>Support showing original instead of translated video titles</li>
          <li>Support showing dislikes</li>
          <li>Support autohide toolbar and show on hover</li>
        </ul>
      </description>
    </release>
    <release version="0.2.10" date="2026-06-01">
      <description>
        <ul>
          <li>Support picture in picture</li>
          <li>Support starring video/channel from context menu</li>
          <li>Add duplicate tab context menu</li>
          <li>Persist video quality setting</li>
        </ul>
      </description>
    </release>
    <release version="0.2.9" date="2026-05-26">
      <description>
        <ul>
          <li>Support multiple tabs</li>
          <li>Add check for update in settings</li>
          <li>Support opening YouTube URLs from command line and flatpak run</li>
          <li>Support blocking channel and keyword</li>
          <li>Support custom user script</li>
          <li>Support hiding community posts</li>
          <li>Support Japanese, Vietnamese, and Traditional Chinese</li>
        </ul>
      </description>
    </release>
    <release version="0.2.8" date="2026-05-13">
      <description>
        <ul>
          <li>Support h264ify</li>
          <li>Support avoiding clickbait thumbnail</li>
          <li>Implement in app language setting</li>
          <li>Support importing localized takeout data</li>
          <li>Support downloading mp3</li>
          <li>Apply custom style without needing to reload page</li>
          <li>Disable queue autoplay when video belongs to playlist</li>
        </ul>
      </description>
    </release>
    <release version="0.2.7" date="2026-04-07">
      <description>
        <ul>
          <li>Fix flatpak download path</li>
        </ul>
      </description>
    </release>
    <release version="0.2.6" date="2026-04-07">
      <description>
        <ul>
          <li>Support downloading videos</li>
          <li>Support light mode and user-defined styles</li>
          <li>Support hiding mix playlists</li>
          <li>Redesign settings modal and improve user styles dialog</li>
          <li>Add in-app changelog</li>
        </ul>
      </description>
    </release>
    <release version="0.2.5" date="2026-03-18">
      <description>
        <ul>
          <li>Redesigned feed modal with advanced filtering and management</li>
          <li>Improve syncing process</li>
        </ul>
      </description>
    </release>
    <release version="0.2.4" date="2026-03-10">
      <description>
        <ul>
          <li>Add share menu to bookmark/history/feed item</li>
          <li>Add German and Portuguese translations</li>
          <li>Improve library and feed loading performance</li>
          <li>Improve importing process</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-02-20">
      <description>
        <ul>
          <li>Fix importing from yt takeout on Windows</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-02-19">
      <description>
        <ul>
          <li>Fix importing from yt takeout</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-02-19">
      <description>
        <ul>
          <li>Support customize user agent</li>
          <li>Support injecting cookies.txt</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-02-08">
      <description>
        <ul>
          <li>Fix ad blocking</li>
          <li>Support injecting cookie to fix login</li>
          <li>Support restoring progress from History panel</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
